{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake Configure",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}",
        "-B",
        "${workspaceFolder}/build"
      ],
      "problemMatcher": []
    },
    {
      "label": "CMake Build",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/build"
      ],
      "dependsOn": "CMake Configure",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ]
    },
    {
      "label": "avr: size",
      "type": "shell",
      "command": "avr-size",
      "args": [
        //"--mcu=atmega324pb",
        "--format=avr",
        "${workspaceFolder}/build/CasseteController.elf"
      ],
      "dependsOn": "AVR Build",
      "problemMatcher": []
    },
    {
      "label": "avr: flash (usbasp)",
      "type": "shell",
      "command": "avrdude",
      "args": [
        "-p",
        "m324pb",
        "-c",
        "usbasp",
        "-U",
        "flash:w:${workspaceFolder}/build/CasseteController.hex:i"
      ],
      "dependsOn": [
        "CMake Build",
        "avr: build hex"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "avr: clean",
      "type": "shell",
      "command": "rm",
      "args": [
        "-rf",
        "${workspaceFolder}/build"
      ],
      "problemMatcher": []
    },
    {
      "label": "avr: simulate",
      "type": "shell",
      "command": "simavr",
      "args": [
        "-m",
        "atmega324p",
        "-f",
        "16000000",
        "-g",
        "build/CasseteController.elf"
      ],
      "dependsOn": [
        "kill simavr",
        "CMake Build"
      ],
      "dependsOrder": "sequence",
      "problemMatcher": []
    },
    {
      "label": "kill simavr",
      "type": "shell",
      "command": "pkill -x simavr || true",
      "args": []
    }
  ]
}